{
  "manifest_version": 2,
  "name": "PurpleAdBlock",
  "version": "1.0.0",
  "description": "Block Twitch ads via a local HLS proxy. No quality drop, no interruptions.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "PurpleAdBlock"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "tabs",
    "*://*.twitchapps.com/*",
    "*://*.twitch.tv/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_security_policy": "script-src 'self'; object-src 'self'"
}