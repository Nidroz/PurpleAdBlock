{
  "manifest_version": 3,
  "name": "PurpleAdBlock",
  "version": "1.0.0",
  "description": "Block Twitch ads via a local HLS proxy. No quality drop, no interruptions.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "PurpleAdBlock"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "*://usher.twitchapps.com/*.m3u8*",
    "*://*.hls.twitchapps.com/*.m3u8*",
    "*://*.abs.hls.twitchapps.com/*.m3u8*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}