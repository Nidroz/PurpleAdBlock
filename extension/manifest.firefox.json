{
  "manifest_version": 2,
  "name": "PurpleAdBlock",
  "version": "2.0.0",
  "description": "Avoid Twitch ads via an ad-free playlist relay. No quality drop, no interruptions.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "PurpleAdBlock"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "*://*.twitch.tv/*",
    "https://usher.ttvnw.net/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_security_policy": "script-src 'self'; object-src 'none'"
}